# ── MySQL ──────────────────────────────────────────────────────────────────────
# These are used by the entrypoint to create the DB + user on first boot.
# DATABASE_URL is overridden in docker-compose.yml to use 127.0.0.1 (localhost).
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=crypto_trader
MYSQL_USER=trader
MYSQL_PASSWORD=change_me_trader

# ── Redis / Celery ─────────────────────────────────────────────────────────────
# Overridden in docker-compose.yml — left here as documentation only.
# Inside the container all services connect via 127.0.0.1 (localhost).
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# ── Coinbase Advanced Trade API ────────────────────────────────────────────────
# From your CDP portal JSON key file (portal.cdp.coinbase.com)
COINBASE_API_KEY=organizations/YOUR_ORG_ID/apiKeys/YOUR_KEY_ID
COINBASE_API_SECRET="-----BEGIN EC PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END EC PRIVATE KEY-----\n"

# ── CoinGecko (free tier — no key needed, but pro key increases limits) ────────
COINGECKO_API_KEY=

# ── CryptoPanic (free key from cryptopanic.com/api) ───────────────────────────
CRYPTOPANIC_API_KEY=your_free_key_here

# ── Anthropic (Claude AI) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── Trading config ─────────────────────────────────────────────────────────────
PAPER_TRADING_INITIAL_BALANCE=10000.00   # virtual USD to start with
MAX_POSITION_PCT=0.10                    # max 10% of portfolio per trade
STOP_LOSS_PCT=0.03                       # 3% stop-loss
MIN_AI_CONFIDENCE=0.70                   # minimum Claude confidence to trade
MAX_OPEN_POSITIONS=5

# ── Watchlist (comma-separated Coinbase product IDs) ──────────────────────────
WATCHLIST=BTC-USD,ETH-USD,SOL-USD,DOGE-USD,AVAX-USD

# ── Flask ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change_me_flask_secret
FLASK_ENV=development

# ── AI Provider ────────────────────────────────────────────────────────────────
# Set AI_PROVIDER to switch between providers — no code changes needed.
# Options: groq (default, free) | anthropic (production)
AI_PROVIDER=groq

# Groq — free tier, fast. Get key at: https://console.groq.com
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic — more reliable JSON, better for live trading
# ANTHROPIC_API_KEY=sk-ant-your_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-5
